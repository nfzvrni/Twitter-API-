<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="RegressionSuite">
	<test name="RegressionTests">
		<groups>
			<run>
				<include name="regression" />
			</run>
		</groups>
		<classes>
			<class name="com.twitterapi.functionality.CreateTweetTest" />
			<class name="com.twitterapi.functionality.LatestTweetsTest" />
			<class name="com.twitterapi.functionality.ReTweetTest" />
			<class name="com.twitterapi.functionality.TrendsByLocationTest" />
			<class name="com.twitterapi.functionality.SendDirectMessageTest" />
			<class name="com.twitterapi.functionality.FriendListTest" />
			<class name="com.twitterapi.functionality.NegativeTests" />
		</classes>
	</test>
</suite>
